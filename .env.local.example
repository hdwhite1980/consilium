# ── Supabase ──────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Core AI APIs ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AIza...

# ── Phase 1: Market Data (free paper account) ─────────────────
# Sign up: alpaca.markets → paper trading account
ALPACA_API_KEY=your-alpaca-key-id
ALPACA_SECRET_KEY=your-alpaca-secret-key
ALPACA_BASE_URL=https://data.alpaca.markets

# ── Phase 2: Fundamentals (free tier, 60 req/min) ────────────
# Sign up: finnhub.io → instant free key
FINNHUB_API_KEY=your-finnhub-key

# ── Phase 4: Options Flow (free sandbox) ──────────────────────
# Sign up: tradier.com/create/account
# Sandbox is free. For live: change URL to api.tradier.com/v1
TRADIER_API_KEY=your-tradier-token

# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
